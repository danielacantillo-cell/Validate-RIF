# === CONFIGURACIÓN GENERAL ===
PROJECT_NAME="Validador RIF SENIAT"
TZ=America/Caracas
MAX_CONCURRENCY=5

# === BASE DE DATOS (Compartida) ===
# Nota: Si usas Docker, el HOST debe ser el nombre del servicio (db)
DB_HOST=db
DB_POSTGRESDB_USER=n8n_admin
DB_POSTGRESDB_DATABASE=n8n_database
SERVER_PASSWORD=password_seguro_db
DB_POSTGRESDB_PORT=5432

# === CONFIGURACIÓN N8N ===
N8N_HOST=localhost
N8N_PORT=5678
N8N_ENCRYPTION_KEY=tu_clave_secreta_pro_2026
N8N_PAYLOAD_SIZE_MAX=1024
N8N_VERSION_NOTIFICATIONS_ENABLED=false

# Pruning (Limpieza de datos para no llenar el disco)
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=240

# Librerías externas (JS para n8n)
NODE_OPTIONS=--max-old-space-size=4096
NODE_FUNCTION_ALLOW_EXTERNAL=axios,lodash,moment,cheerio,exceljs,pandas,requests

# === CONFIGURACIÓN FASTAPI / MISTRAL ===
API_PORT=8000
FASTAPI_API_KEY=api_key_fastapi_segura
MISTRAL_API_KEY=v7x_tu_clave_real_de_mistral_aqui
